{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(python scripts/*)",
      "Bash(python3 scripts/*)",
      "Bash(*python scripts/*)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(git checkout --*)",
      "Bash(rm -rf /*)"
    ]
  }
}
