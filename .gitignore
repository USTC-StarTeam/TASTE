# framework: track source, prompts, templates, docs, and project config.
# Do NOT track downloaded research repos, datasets, runs, generated papers, logs, or caches.

# Python / node caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.vscode/
.DS_Store
framework/.venv/
web/frontend/client/node_modules/
web/frontend/client/dist/
web/frontend/client/tsconfig.tsbuildinfo

# Runtime logs and temporary files
*.log
logs/
tmp/
.tmp/
tmp_*.txt
.probe/
.runtime/
taste_web*.log
backups/

# Local workspace config and maintainer notes. Keep framework/resources templates in Git,
# but never publish a machine-specific default project, API-key state, or maintainer handoff.
/config.json
/工作状态.txt
**/工作状态.txt
**/测试报告.md
/handoff/

# Imported local patch bundles, macOS resource forks, and manual pre-patch copies.
# They are useful as local recovery material but are not part of the framework.
local_imports_from_mac/
.claude/settings.json
.claude/scheduled_tasks.json
.claude/projects/
framework/resources/claude/projects/
._*
**/._*
*.orig
*.rej

# External reference checkouts are kept on disk for provenance/sync, but the
# TASTE tracks adapters and manifests rather than vendored git repos.
third_party/
modules/writing/vendor/

# Top-level generated research outputs
artifacts/
obsidian/
raw/
discover/
reports/
state/
wiki/
shared/
gaps/
wandb/
outputs/

# Large artifacts anywhere
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.npz
*.npy
*.parquet
*.csv
*.tsv
*.pdf
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# Legacy generated runtime dirs retained only for ignore compatibility.
framework/auto_research/runs/
framework/auto_research/.config.json
framework/auto_research/local_database/

# Per-project generated state and research-object material.
# Project workspaces are private/runtime by default. They often include local
# paths, API-key state, downloaded repos, datasets, generated papers, and
# unpublished scientific conclusions. Use framework/resources/templates/project.json and
# framework/scripts/create_project.py to create a local project after cloning.
projects/*
!projects/.gitkeep
